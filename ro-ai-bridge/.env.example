# Server
PORT=8080

# Database (MariaDB)
MARIADB_URL=mysql://mimir:mimir_password@localhost:3306/mimir

# Vector DB (Qdrant)
QDRANT_URL=http://localhost:6333

# Cache (Redis)
REDIS_URL=redis://localhost:6379

# LLM - Ollama (Local)
OLLAMA_API_URL=http://localhost:11434/v1
OLLAMA_URL=http://localhost:11434
LOCAL_MODEL=gemma:2b
EMBED_MODEL=nomic-embed-text

# LLM - Gemini (Cloud)
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# RustFS / S3
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=mimir-tenant-uploads
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1

# JWT Authentication
JWT_SECRET=your_jwt_secret_here

# Structured Logging (Sprint 14)
# Options: error, warn, info, debug, trace
# Module-specific: RUST_LOG=ro_ai_bridge=debug,mimir_core_ai=info
RUST_LOG=info

# Cron Worker (Sprint 14)
CRON_TICK_SECONDS=60

# OpenAI (optional, for GPT models)
OPENAI_API_KEY=your_openai_key_here

# GitHub Integration — Feedback auto-creates issues (Sprint 14)
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_REPO_OWNER=megacare-dev
GITHUB_REPO_NAME=Project-Mimir
