# Server
PORT=8080

# Database (MariaDB)
MARIADB_URL=mysql://mimir:REDACTED-PW@localhost:3306/mimir

# Vector DB (Qdrant)
QDRANT_URL=http://localhost:6333

# Cache (Redis)
REDIS_URL=redis://localhost:6379

# LLM Gateway — Heimdall (Handles all LLM routing: Local, Gemini, OpenRouter)
HEIMDALL_API_URL=http://localhost:3000/v1
HEIMDALL_API_KEY=gateway_key_here
HEIMDALL_MODEL=mlx-community/Qwen3.5-35B-A3B-4bit

# Hermodr — Universal MCP Sidecar (per-upstream deployments)
# Set the JSON-RPC endpoint of each Hermodr instance you want Mimir's MCP
# to surface to agents. Leaving any blank disables that tool group.
# See Asgard MultiAgent Architecture Plan §"Hybrid Tool Placement".
HERMODR_EIR_MEDICAL_URL=
# Examples (one Hermodr per upstream for independent rate-limiting):
#   HERMODR_PUBMED_URL=http://hermodr-pubmed.asgard.svc:8090/rpc
#   HERMODR_TRIALS_URL=http://hermodr-trials.asgard.svc:8090/rpc
#   HERMODR_FDA_URL=http://hermodr-fda.asgard.svc:8090/rpc
#   HERMODR_RXNAV_URL=http://hermodr-rxnav.asgard.svc:8090/rpc
#   HERMODR_WEBFETCH_URL=http://hermodr-webfetch.asgard.svc:8090/rpc
#   HERMODR_MEDCALC_URL=http://hermodr-medcalc.asgard.svc:8090/rpc

# RustFS / S3
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=mimir-tenant-uploads
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1

# JWT Authentication
JWT_SECRET=your_jwt_secret_here

# Structured Logging (Sprint 14)
# Options: error, warn, info, debug, trace
# Module-specific: RUST_LOG=ro_ai_bridge=debug,mimir_core_ai=info
RUST_LOG=info

# Cron Worker (Sprint 14)
CRON_TICK_SECONDS=60



# GitHub Integration — Feedback auto-creates issues (Sprint 14)
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_REPO_OWNER=megacare-dev
GITHUB_REPO_NAME=Project-Mimir

# HashiCorp Vault — Secrets Management (Sprint 14)
# Leave empty or remove to use env vars only (no Vault)
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=mimir-dev-token
VAULT_MOUNT=secret
VAULT_PATH=mimir

# ═══════════════════════════════════════
# 🔐 Default Local Credentials (Dev Only)
# ═══════════════════════════════════════
# Mimir / Zitadel Admin:
#   User: zitadel-admin@asgard.localhost
#         (or admin@asgardai.dev / admin@asgard.ai based on migration)
#   Pass: admin123 
#         (or REDACTED-PW if using Masterkey init)
#
# OpenEMR (Eir) Admin:
#   User: admin
#   Pass: 1qazXSW@
