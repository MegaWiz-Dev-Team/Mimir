# ==============================================================
# BIFROST ENVIRONMENT DEPLOYMENT CONFIGURATION (RAG TELEMETRY)
# ==============================================================

# OTLP_ENDPOINT
# Instructs the ro-ai-bridge to enable the OpenTelemetry Trace Exporter.
# Must point to the Vardr gRPC (4317) or HTTP (4318) ingress port.
OTLP_ENDPOINT="http://vardr-service.mimir.internal:4317"

# VARDR_AUTH_TOKEN (Optional)
# If Vardr requires authorization, insert the plain Bearer token below.
# The bridge will automatically format and inject `Authorization: Bearer <token>`
# into the gRPC metadata payload before dispatching metrics.
VARDR_AUTH_TOKEN="vdr_telemetry_secure_key_123456"

# ==============================================================
# BIFROST PERFORMANCE OVERHEADS 
# ==============================================================
# If running inside Kubernetes / Docker Compose:
# Memory Limits: +50MB buffering for BatchSpanProcessor
# Ensure egress firewall policies explicitly whitelist the OTLP_ENDPOINT URL.
