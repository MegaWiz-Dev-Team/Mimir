# Insurance Ingestion Pipeline — Environment Configuration

# Mimir API
MIMIR_BASE_URL=http://mimir.asgard.svc:8000
MIMIR_TENANT_ID=asgard_insurance

# Embeddings (Heimdall)
EMBEDDINGS_ENDPOINT=http://heimdall.asgard.svc:8001/embed
EMBEDDINGS_MODEL=bge-m3

# Neo4j (Knowledge Graph)
NEO4J_URI=bolt://neo4j.asgard.svc:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# Qdrant (Vector DB)
QDRANT_URL=http://qdrant.asgard.svc:6333
QDRANT_COLLECTION=insurance_products

# Pipeline Config
BATCH_SIZE=100
SOURCE_BASE_DIR=./data/sources
OUTPUT_DIR=./data/output
TEST_MODE=false

# Logging
LOG_LEVEL=INFO
QUIET_MODE=false

# Fallback (Plan B)
FALLBACK_EMBEDDING_MODEL=typhoon
FALLBACK_HIT_RATE_THRESHOLD=0.50
