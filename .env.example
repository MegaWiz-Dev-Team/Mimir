# ============================================================================
# Project Mimir — Environment Configuration Template
# ============================================================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# Required variables are marked with [REQUIRED]
# Optional variables have defaults shown in comments
# ============================================================================

# ── Database (MariaDB) ────────────────────────────────────────────────────
# [REQUIRED] Database connection URL for the Bridge API
DATABASE_URL=mysql://mimir:mimir_password@localhost:3306/mimir

# MariaDB container settings
MARIADB_ROOT_PASSWORD=root
MARIADB_DATABASE=mimir
MARIADB_USER=mimir
MARIADB_PASSWORD=mimir_password
MARIADB_HOST=localhost
MARIADB_PORT=3306

# ── Redis ─────────────────────────────────────────────────────────────────
# Cache and session storage
REDIS_URL=redis://localhost:6379
REDIS_PORT=6379

# ── Qdrant (Vector Database) ─────────────────────────────────────────────
# Vector similarity search
QDRANT_URL=http://localhost:6333
QDRANT_PORT=6333

# ── RustFS (Object Storage) ──────────────────────────────────────────────
# S3-compatible file storage
RUSTFS_ENDPOINT=http://localhost:9000
RUSTFS_ROOT_USER=minioadmin
RUSTFS_ROOT_PASSWORD=minioadmin
RUSTFS_PORT=9000
RUSTFS_CONSOLE_PORT=9001

# ── Vault (Secrets Management) ───────────────────────────────────────────
# HashiCorp Vault for API key management (optional)
# Leave empty to use env vars directly
VAULT_ADDR=http://localhost:8201
VAULT_TOKEN=mimir-dev-token
VAULT_MOUNT=secret
VAULT_PATH=mimir
VAULT_PORT=8201
VAULT_DEV_ROOT_TOKEN_ID=mimir-dev-token

# ── LLM Configuration ────────────────────────────────────────────────────
# [REQUIRED] At least one LLM provider API key
GEMINI_API_KEY=your_gemini_api_key_here

# MLX Server (local, optional)
# MLX_ENDPOINT=http://localhost:8080
# MLX_MODEL=mlx-community/Mistral-7B-Instruct-v0.3-4bit

# vLLM Server (local, optional)
# VLLM_ENDPOINT=http://localhost:8000
# VLLM_MODEL=mistralai/Mistral-7B-Instruct-v0.3

# Heimdall Self-Hosted LLM Gateway (optional)
# HEIMDALL_API_URL=http://localhost:8080/v1
# HEIMDALL_API_KEY=your_heimdall_api_key_here
# HEIMDALL_MODEL=mlx-community/Qwen3.5-35B-A3B-4bit

# ── Bridge API ────────────────────────────────────────────────────────────
# [REQUIRED] JWT secret for authentication
JWT_SECRET=change_me_to_a_secure_random_string

# Bridge server port (default: 3000)
PORT=3000

# Logging level (info, debug, warn, error)
RUST_LOG=info

# ── Dashboard ─────────────────────────────────────────────────────────────
# Next.js dashboard settings
NEXT_PUBLIC_API_URL=http://localhost:3000

# ── Cron / Scheduler ─────────────────────────────────────────────────────
# Cron tick interval in seconds (default: 60)
CRON_TICK_SECONDS=60

# ── Backup ────────────────────────────────────────────────────────────────
# Backup directory (default: ./data/backups)
BACKUP_DIR=./data/backups
BACKUP_DAILY_RETENTION=7
BACKUP_WEEKLY_RETENTION=4

# ── GitHub Integration (Feedback) ─────────────────────────────────────────
# For creating issues from in-app feedback (optional)
# GITHUB_TOKEN=ghp_xxxxxxxxxxxx
# GITHUB_REPO=megacare-dev/Project-Mimir
